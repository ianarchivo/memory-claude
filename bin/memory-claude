#!/usr/bin/env bash
# memory-claude — wrap `claude` with a keyed shared-memory pool across sessions.
# usage: memory-claude [<key>] [<subcommand>] [args...]

set -euo pipefail

# Resolve script's source location to find src/, even via symlink.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  target=$(readlink "$SCRIPT_PATH")
  if [[ "$target" = /* ]]; then
    SCRIPT_PATH="$target"
  else
    SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && cd "$(dirname "$target")" && pwd)/$(basename "$target")"
  fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC="$REPO_ROOT/src"
LIB="$SRC/lib"
CMD="$SRC/cmd"

# Default install root for hook script discovery (used by start.sh)
export MC_ROOT="${MC_ROOT:-$HOME/.memory-claude}"

# shellcheck disable=SC1091
source "$LIB/core.sh"

usage() {
  cat <<EOF
memory-claude — keyed shared memory across Claude Code sessions

Launch:
  memory-claude                          mint a random key and start a session
  memory-claude new <key>                mint a specific key name (errors if exists)
  memory-claude <key>                    join <key> if it exists, else mint it
  memory-claude <key> --resume <uuid>    resume a specific session under the key
  memory-claude <key> -- <claude-args>   pass remaining args directly to claude

Inspect:
  memory-claude list                     list all known keys
  memory-claude <key> list               list sessions on this key
  memory-claude <key> monitor            live view of sessions + pool
  memory-claude <key> show               print pool.md
  memory-claude <key> tail [-n N] [-f]   tail pool.ndjson decoded
  memory-claude <key> search "<q>" [...] full-text search the pool
  memory-claude <key> compact            rotate + render pool.md

Write:
  memory-claude <key> note "<text>" [--tag a,b]
                                         append a manual note to the pool

Manage:
  memory-claude <key> destroy [--yes]    delete key dir
  memory-claude doctor                   smoke-test the install
  memory-claude --version
  memory-claude --help

Env:
  MEMORY_CLAUDE_COMPRESS=auto            prefer Haiku when ANTHROPIC_API_KEY
                                         is set; fall back to rule-based.
                                         Other values: rule-based (default),
                                         haiku (force Haiku).
  MEMORY_CLAUDE_TAGS=a,b                 allowlist: only inject delta entries
                                         whose tags intersect this set.
  MEMORY_CLAUDE_EXCLUDE_TAGS=x,y         blocklist: skip entries with these tags.
  MEMORY_CLAUDE_TAGS_STRICT=1            with MEMORY_CLAUDE_TAGS set, exclude
                                         untagged entries too.
  MEMORY_CLAUDE_DEBUG=1                  persist per-turn injection deltas to
                                         snapshots/<sid>-turn-<epoch>.md.
EOF
}

VERSION="0.1.0"

# A subcommand is any executable .sh in src/cmd/. This auto-discovers new
# commands (e.g. note, search) without editing this file.
is_subcommand() {
  [[ -n "$1" && -f "$CMD/${1}.sh" ]]
}

is_valid_key() {
  # 2-64 chars, lowercase letter first, then a-z 0-9 or dashes, no trailing dash.
  [[ "$1" =~ ^[a-z][a-z0-9-]{0,62}[a-z0-9]$ ]]
}

# Top-level flags
case "${1:-}" in
  "-h"|"--help") usage; exit 0 ;;
  "--version") echo "memory-claude $VERSION"; exit 0 ;;
  "doctor") exec bash "$CMD/doctor.sh" ;;
  "list")
    # `memory-claude list` (no key) -> list all keys
    exec bash "$CMD/list.sh"
    ;;
  "new")
    # `memory-claude new <key>` -> mint a specific key name (errors if exists).
    # Remaining args forward to claude unchanged.
    shift
    NEW_KEY="${1:-}"
    if [[ -z "$NEW_KEY" ]]; then
      echo "memory-claude new: key name required" >&2
      echo "usage: memory-claude new <key> [claude-args...]" >&2
      exit 1
    fi
    shift
    if ! is_valid_key "$NEW_KEY"; then
      echo "memory-claude: '$NEW_KEY' is not a valid key name." >&2
      echo "Keys must be 2-64 chars, lowercase, start with a letter, contain only a-z 0-9 and dashes." >&2
      exit 1
    fi
    if [[ -d "$MC_ROOT/$NEW_KEY" ]]; then
      echo "memory-claude: key '$NEW_KEY' already exists at $MC_ROOT/$NEW_KEY." >&2
      echo "Use 'memory-claude $NEW_KEY' to join it, or pick a different name." >&2
      exit 1
    fi
    exec bash "$CMD/start.sh" "$NEW_KEY" "$@"
    ;;
  "")
    # `memory-claude` with no args -> mint a new key and launch.
    # `memory-claude "" something` -> reject; ambiguous.
    if [[ $# -gt 1 ]]; then
      echo "memory-claude: empty key is not allowed with extra arguments." >&2
      echo "Run 'memory-claude' to mint a key, or provide one explicitly." >&2
      exit 1
    fi
    exec bash "$CMD/start.sh" ""
    ;;
  "--")
    # `memory-claude -- <claude-args>` -> mint a key, pass everything else to claude
    shift
    exec bash "$CMD/start.sh" "" "$@"
    ;;
esac

# If first arg is a claude-style flag, mint a key and pass through to claude.
if [[ "${1:0:1}" == "-" ]]; then
  exec bash "$CMD/start.sh" "" "$@"
fi

# Otherwise the first arg is treated as a key (or a subcommand without one).
ARG1="$1"; shift || true

# Case: first arg is a subcommand without a key. Reject (with the exception of
# `list` and `doctor`, already handled above).
if is_subcommand "$ARG1"; then
  echo "memory-claude: subcommand '$ARG1' requires a key. usage: memory-claude <key> $ARG1" >&2
  exit 1
fi

# Validate the key name.
if ! is_valid_key "$ARG1"; then
  echo "memory-claude: '$ARG1' is not a valid key name." >&2
  echo "Keys must be 2-64 chars, lowercase, start with a letter, contain only a-z 0-9 and dashes." >&2
  exit 1
fi

KEY="$ARG1"
SUBCMD="${1:-}"

# If next arg is a recognized subcommand, dispatch to it.
if [[ -n "$SUBCMD" ]] && is_subcommand "$SUBCMD"; then
  shift
  exec bash "$CMD/${SUBCMD}.sh" "$KEY" "$@"
fi

# Otherwise: launch (mint or join). Remaining args go to claude.
exec bash "$CMD/start.sh" "$KEY" "$@"
